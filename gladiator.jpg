<!DOCTYPE html>
<html>
<head>
  <title>My Gladiator Portfolio</title>

  <style>
    body {
      background-color: black;
      color: white;
      font-family: Arial, sans-serif;
      text-align: center;
    }

    h1 {
      font-size: 40px;
      margin-top: 20px;
    }

    h2 {
      margin-top: 40px;
      color: gold;
    }

    img {
      width: 300px;
      border-radius: 12px;
      margin-top: 20px;
    }

    .section {
      margin: 40px;
    }

    a {
      color: gold;
      text-decoration: none;
      font-weight: bold;
    }

    a:hover {
      color: red;
    }

    .button {
      display: inline-block;
      margin-top: 15px;
      padding: 10px 20px;
      border: 2px solid gold;
      border-radius: 8px;
    }
  </style>
</head>

<body>

  <h1>⚔️ My Gladiator Portfolio ⚔️</h1>

  <div class="section">
    <h2>About Me</h2>
    <p>I am strong, focused, and building my future like a gladiator.</p>
  </div>

  <div class="section">
    <h2>Gladiator Spirit</h2>
    <img src="https://images.unsplash.com/photo-1608889175123-8ee362a1c6b1" alt="Gladiator">
  </div>

  <div class="section">
    <h2>My Work</h2>
    <p>Project 1 - Coming soon</p>
    <p>Project 2 - Coming soon</p>
  </div>

  <div class="section">
    <h2>Resume</h2>
    <a href="#" class="button">Download My Resume</a>
  </div>

</body>
</html>
